.profile-card {
  padding: var(--space-24);
  margin-bottom: var(--space-16);
}

.profile-header {
  display: flex;
  align-items: center;
  gap: var(--space-16);
  margin-bottom: var(--space-24);
}

.profile-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: var(--color-bg-soft);
  flex-shrink: 0;
}

.profile-center {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.profile-nickname {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.profile-bio {
  font-size: var(--font-caption);
  color: var(--color-text-secondary);
}

.profile-hearts {
  display: flex;
  align-items: center;
  gap: 6rpx;
  flex-shrink: 0;
}

.hearts-icon {
  font-size: 28rpx;
  color: var(--color-accent);
}

.hearts-number {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-accent);
}

.profile-stats {
  display: flex;
  align-items: center;
  padding-top: var(--space-20);
  border-top: 1rpx solid var(--color-border, #e5dfd5);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-number {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.stat-label {
  font-size: var(--font-note, 22rpx);
  color: var(--color-text-secondary);
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: var(--color-border, #e5dfd5);
}

.section-card {
  padding: var(--space-20) var(--space-24);
  margin-bottom: var(--space-12);
}

.section-card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-card-title {
  font-size: 30rpx;
  color: var(--color-text-primary);
}

.section-card-arrow {
  font-size: 32rpx;
  color: var(--color-text-secondary);
  transition: transform 0.3s ease;
  display: inline-block;
}

.section-card-arrow.arrow-up {
  transform: rotate(90deg);
}

.history-list {
  margin-top: var(--space-16);
  padding-top: var(--space-16);
  border-top: 1rpx solid var(--color-border, #e5dfd5);
}

.history-empty {
  padding: var(--space-20) 0;
  text-align: center;
  color: var(--color-text-secondary);
  font-size: var(--font-caption);
}

.history-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-16) 0;
  border-bottom: 1rpx solid var(--color-border, #e5dfd5);
}

.history-item:last-child {
  border-bottom: none;
}

.history-item-left {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.history-title {
  font-size: 28rpx;
  color: var(--color-text-primary);
}

.history-ending {
  font-size: var(--font-note, 22rpx);
  color: var(--color-accent);
}

.history-date {
  font-size: var(--font-note, 22rpx);
  color: var(--color-text-secondary);
  flex-shrink: 0;
}
