<view class="page-shell settings-page" style="{{themeStyle}}">
  <view class="settings-nav" style="padding-top: {{statusBarHeight}}px">
    <view class="settings-nav__bar">
      <view class="settings-nav__back" bindtap="handleBack">‹</view>
      <text class="settings-nav__title serif-title">设置</text>
      <view class="settings-nav__back settings-nav__back--placeholder"></view>
    </view>
  </view>

  <!-- 外观 -->
  <view class="settings-section">
    <text class="settings-section__label">外观</text>
    <view class="settings-card">
      <view class="settings-row">
        <text class="settings-row__label">字体大小</text>
        <view class="font-size-group">
          <view class="font-size-btn {{fontSize === 'sm' ? 'font-size-btn--active' : ''}}" bindtap="handleFontSize" data-size="sm">
            <text class="font-size-btn__text font-size-btn__text--sm">小</text>
          </view>
          <view class="font-size-btn {{fontSize === 'md' ? 'font-size-btn--active' : ''}}" bindtap="handleFontSize" data-size="md">
            <text class="font-size-btn__text font-size-btn__text--md">中</text>
          </view>
          <view class="font-size-btn {{fontSize === 'lg' ? 'font-size-btn--active' : ''}}" bindtap="handleFontSize" data-size="lg">
            <text class="font-size-btn__text font-size-btn__text--lg">大</text>
          </view>
        </view>
      </view>
      <view class="settings-row settings-row--border">
        <view class="settings-row__body">
          <text class="settings-row__label">护眼模式</text>
          <text class="settings-row__sub">深暖棕背景，减少长时间阅读疲劳</text>
        </view>
        <switch color="#8b5a5a" checked="{{eyeCare}}" bindchange="handleEyeCare" />
      </view>
    </view>
  </view>

  <!-- 数据 -->
  <view class="settings-section">
    <text class="settings-section__label">数据</text>
    <view class="settings-card">
      <view class="settings-row" bindtap="handleClearCache">
        <text class="settings-row__label">清理本地缓存</text>
        <text class="settings-row__arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 其他 -->
  <view class="settings-section">
    <text class="settings-section__label">其他</text>
    <view class="settings-card">
      <view class="settings-row" bindtap="handlePrivacy">
        <text class="settings-row__label">隐私协议</text>
        <text class="settings-row__arrow">›</text>
      </view>
      <view class="settings-row settings-row--border" bindtap="handleAbout">
        <text class="settings-row__label">关于如果这样回</text>
        <text class="settings-row__arrow">›</text>
      </view>
    </view>
  </view>
</view>
