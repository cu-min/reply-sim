.chat-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--color-bg-page);
  padding-top: var(--space-12);
  padding-bottom: calc(var(--space-24) + env(safe-area-inset-bottom));
}

.chat-topbar {
  display: flex;
  align-items: center;
  margin-bottom: var(--space-8);
}

.chat-title-group {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.chat-name {
  display: block;
  width: 100%;
  font-size: var(--font-title-md);
  font-weight: 600;
  text-align: center;
  line-height: 1.2;
  font-family: "Songti SC", "STSong", "Noto Serif SC", serif;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  writing-mode: horizontal-tb;
}

.chat-status {
  display: block;
  width: 100%;
  margin-top: 6rpx;
  color: var(--color-text-secondary);
  font-size: var(--font-caption);
  text-align: center;
  line-height: 1.5;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  writing-mode: horizontal-tb;
}

.chat-turn {
  display: block;
  margin: 0 0 var(--space-8);
  color: var(--color-highlight);
  font-size: var(--font-caption);
  text-align: center;
}

.chat-restore {
  display: block;
  margin-bottom: var(--space-12);
  color: var(--color-text-muted);
  font-size: var(--font-note);
  text-align: center;
}

.chat-panel {
  flex: 1;
  min-height: 0;
  padding: var(--space-16) 0;
  background: transparent;
}

.chat-bottom,
.finish-panel {
  padding: var(--space-20);
  background: #ffffff;
}

.bottom-group + .bottom-group {
  margin-top: var(--space-20);
}

.intent-description,
.composer-note {
  display: block;
  margin-top: var(--space-8);
  color: var(--color-text-secondary);
  font-size: var(--font-caption);
}

.reply-stage-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--space-12);
}

.reply-stage-copy {
  flex: 1;
  min-width: 0;
}

.stage-back-button {
  min-height: 44rpx;
  min-width: 88rpx;
  padding: 0 14rpx;
  border-radius: var(--radius-pill);
  border: 1rpx solid var(--color-border-soft);
  background: var(--color-bg-soft);
  color: var(--color-accent);
  font-size: 22rpx;
  flex-shrink: 0;
}

.selected-intent-badge {
  display: inline-flex;
  margin-top: var(--space-12);
  padding: 10rpx 18rpx;
  border-radius: var(--radius-pill);
  background: var(--color-accent-soft);
  color: var(--color-accent);
  font-size: var(--font-caption);
}

.intent-item + .intent-item,
.reply-item + .reply-item {
  margin-top: var(--space-12);
}

.composer {
  width: 100%;
  min-height: 132rpx;
  margin-top: var(--space-12);
  padding: var(--space-16);
  border-radius: var(--radius-input);
  background: var(--color-bg-soft);
  border: 1rpx solid var(--color-border-soft);
}

.composer-actions {
  display: flex;
  align-items: center;
  gap: var(--space-12);
  margin-top: var(--space-16);
}

.composer-clear {
  width: 180rpx;
  flex-shrink: 0;
}

.send-button {
  flex: 1;
}

.send-button--disabled {
  opacity: 0.45;
}

.finish-button {
  margin-top: var(--space-16);
}

.finish-copy {
  display: block;
  margin: var(--space-12) 0 var(--space-20);
  color: var(--color-text-secondary);
}
