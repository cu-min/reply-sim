/* ── Page shell ─────────────────────────────────────── */
.chat-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--color-bg-page);
}

/* ── Top nav bar ─────────────────────────────────────── */
.chat-topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 20rpx 14rpx;
  background: rgba(245, 240, 232, 0.92);
  backdrop-filter: blur(12px);
  border-bottom: 1rpx solid var(--color-border-soft);
  flex-shrink: 0;
}

.chat-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.back-chevron {
  font-size: 52rpx;
  color: var(--color-text-primary);
  line-height: 1;
  margin-top: -4rpx;
}

.chat-title-area {
  flex: 1;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2rpx;
}

.chat-name {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  font-family: "Songti SC", "STSong", "Noto Serif SC", serif;
  letter-spacing: 2rpx;
  line-height: 1.3;
}

.chat-subtitle {
  font-size: 22rpx;
  color: var(--color-text-muted);
  line-height: 1.3;
  transition: color 0.2s;
}

.chat-subtitle--typing {
  color: var(--color-accent);
}

.chat-topbar-right {
  width: 64rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  flex-shrink: 0;
}

.topbar-more {
  display: flex;
  gap: 7rpx;
  align-items: center;
  padding: 8rpx;
}

.more-dot {
  width: 7rpx;
  height: 7rpx;
  border-radius: 50%;
  background: var(--color-text-muted);
}

/* ── Restore hint ─────────────────────────────────────── */
.chat-restore {
  display: block;
  padding: 12rpx 32rpx;
  color: var(--color-text-muted);
  font-size: var(--font-note);
  text-align: center;
  flex-shrink: 0;
}

/* ── Chat area ─────────────────────────────────────── */
.chat-panel {
  flex: 1;
  min-height: 0;
  padding: 20rpx 28rpx 0;
}

.chat-timestamp {
  text-align: center;
  margin-bottom: 24rpx;
  font-size: 22rpx;
  color: var(--color-text-muted);
  background: rgba(154, 143, 133, 0.12);
  display: inline-block;
  padding: 5rpx 18rpx;
  border-radius: 999rpx;
  left: 50%;
  position: relative;
  transform: translateX(-50%);
}

/* ── Typing indicator ─────────────────────────────────────── */
.typing-row {
  display: flex;
  align-items: flex-end;
  gap: 14rpx;
  padding: 4rpx 0 16rpx;
}

.typing-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #D4B5A0, #C49A85);
  color: #6B3A2A;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.typing-bubble {
  background: var(--color-bubble-assistant);
  border-radius: 6rpx 28rpx 28rpx 28rpx;
  padding: 18rpx 22rpx;
  display: flex;
  gap: 8rpx;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.typing-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: var(--color-text-muted);
}

.typing-dot--1 { animation: typingBounce 1.2s ease 0s infinite; }
.typing-dot--2 { animation: typingBounce 1.2s ease 0.2s infinite; }
.typing-dot--3 { animation: typingBounce 1.2s ease 0.4s infinite; }

@keyframes typingBounce {
  0%, 80%, 100% { opacity: 0.3; transform: translateY(0); }
  40% { opacity: 1; transform: translateY(-5rpx); }
}

/* ── Bottom panel ─────────────────────────────────────── */
.chat-bottom {
  flex-shrink: 0;
  background: #ffffff;
  border-radius: 40rpx 40rpx 0 0;
  box-shadow: 0 -8rpx 48rpx rgba(0, 0, 0, 0.10);
  border-top: 1rpx solid var(--color-border-soft);
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.panel-handle-wrap {
  display: flex;
  justify-content: center;
  padding: 18rpx 0 0;
}

.panel-handle {
  width: 72rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: var(--color-border-soft);
}

/* Step progress */
.step-progress {
  display: flex;
  gap: 10rpx;
  align-items: center;
  padding: 18rpx 32rpx 0;
}

.step-bar {
  flex: 1;
  height: 6rpx;
  border-radius: 999rpx;
  background: var(--color-border-soft);
  transition: background 0.3s ease;
}

.step-bar--active {
  background: var(--color-accent);
}

.step-bar--done {
  background: rgba(139, 90, 90, 0.35);
}

.direct-toggle {
  width: 52rpx;
  height: 52rpx;
  border-radius: 16rpx;
  background: var(--color-bg-muted);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-left: 8rpx;
  transition: background 0.2s, transform 0.12s;
}

.direct-toggle--on {
  background: var(--color-accent);
}

.direct-toggle--pressed {
  transform: scale(0.92);
}

.direct-toggle-img {
  width: 34rpx;
  height: 34rpx;
}

/* Panel body */
.panel-body {
  padding: 20rpx 28rpx 0;
}

/* ── Step enter animation ─────────────────────────────────────── */
@keyframes stepSlideUp {
  from { opacity: 0; transform: translateY(16rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

@keyframes stepSlideDown {
  from { opacity: 1; transform: translateY(0); }
  to   { opacity: 0; transform: translateY(16rpx); }
}

.step-enter {
  animation: stepSlideUp 0.25s ease-out;
}

.step-leave {
  animation: stepSlideDown 0.25s ease-out forwards;
}

/* ── Intent step ─────────────────────────────────────── */
.panel-hint {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin-bottom: 18rpx;
  letter-spacing: 0.5rpx;
}

.intent-row {
  display: flex;
  gap: 14rpx;
  padding-bottom: 24rpx;
}

.intent-item {
  flex: 1;
  display: flex;
  min-width: 0;
}

/* ── Replies step ─────────────────────────────────────── */
.replies-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 18rpx;
}

.replies-label {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.ai-tag {
  color: var(--color-accent);
  font-weight: 600;
}

.back-link {
  font-size: 24rpx;
  color: var(--color-text-muted);
  padding: 8rpx 4rpx;
  transition: opacity 0.15s;
}

.back-link--pressed {
  opacity: 0.5;
}

.reply-item {
  margin-bottom: 16rpx;
}

.reply-item:last-child {
  margin-bottom: 20rpx;
}

/* ── Edit step ─────────────────────────────────────── */
.edit-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.edit-hint {
  font-size: 22rpx;
  color: var(--color-text-muted);
}

.selected-style-badge {
  display: flex;
  align-items: center;
  gap: 14rpx;
  background: rgba(139, 90, 90, 0.07);
  border-radius: 16rpx;
  padding: 14rpx 18rpx;
  margin-bottom: 16rpx;
}

.selected-style-bar {
  width: 6rpx;
  border-radius: 999rpx;
  align-self: stretch;
  background: linear-gradient(to bottom, #D4B5A0, #C49A85);
  flex-shrink: 0;
}

.selected-style-text {
  font-size: 22rpx;
  color: var(--color-text-muted);
}

.selected-style-name {
  color: var(--color-accent);
  font-weight: 500;
}

/* ── Composer ─────────────────────────────────────── */
.composer {
  width: 100%;
  min-height: 120rpx;
  background: var(--color-bg-soft);
  border: 2rpx solid var(--color-border-soft);
  border-radius: var(--radius-input);
  padding: 18rpx 20rpx;
  font-size: var(--font-body);
  color: var(--color-text-primary);
  line-height: 1.6;
}

.composer-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
  padding-bottom: 4rpx;
}

.ghost-btn {
  flex: 1;
  min-height: 84rpx;
  border-radius: var(--radius-button);
  border: 2rpx solid var(--color-border-strong);
  background: transparent;
  color: var(--color-text-muted);
  font-size: var(--font-body);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.12s ease;
}

.ghost-btn--pressed {
  transform: scale(0.96);
  background: rgba(0, 0, 0, 0.04);
}

.send-btn {
  flex: 2;
  min-height: 84rpx;
  border-radius: var(--radius-button);
  background: var(--color-accent);
  color: #ffffff;
  font-size: var(--font-body);
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 28rpx rgba(139, 90, 90, 0.35);
  transition: transform 0.12s ease, box-shadow 0.12s ease;
}

.send-btn:active {
  transform: scale(0.96);
  box-shadow: 0 4rpx 14rpx rgba(139, 90, 90, 0.25);
}

.send-btn--disabled {
  opacity: 0.45;
}

/* ── Finish panel ─────────────────────────────────────── */
.finish-panel {
  flex-shrink: 0;
  margin: 0 28rpx;
  padding: var(--space-20);
  background: #ffffff;
  border-radius: var(--radius-card);
  box-shadow: var(--shadow-card);
  margin-bottom: calc(var(--space-24) + env(safe-area-inset-bottom));
}

.finish-button {
  margin-top: var(--space-16);
  width: 100%;
}

.finish-copy {
  display: block;
  margin: var(--space-12) 0 var(--space-20);
  color: var(--color-text-secondary);
  font-size: var(--font-body);
}
