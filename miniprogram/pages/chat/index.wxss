.chat-topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-8) var(--space-16) var(--space-12);
}

.chat-back {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
  color: var(--color-text-primary);
  flex-shrink: 0;
}

.chat-back--placeholder {
  pointer-events: none;
  visibility: hidden;
}

.chat-name {
  font-size: 52rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  font-family: "Songti SC", "STSong", "Noto Serif SC", serif;
  letter-spacing: 2rpx;
  text-align: center;
  flex: 1;
}

.chat-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--color-bg-page);
  padding-top: 0;
  padding-bottom: calc(var(--space-24) + env(safe-area-inset-bottom));
}

.chat-restore {
  display: block;
  margin-bottom: var(--space-12);
  color: var(--color-text-muted);
  font-size: var(--font-note);
  text-align: center;
}

.chat-panel {
  flex: 1;
  min-height: 0;
  padding: var(--space-16) 0;
  background: transparent;
}

.chat-bottom,
.finish-panel {
  position: relative;
  padding: var(--space-20);
  background: #ffffff;
}

.bottom-group + .bottom-group {
  margin-top: var(--space-20);
}

.stage-back-icon {
  position: absolute;
  top: var(--space-16);
  left: var(--space-16);
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.stage-back-img {
  width: 44rpx;
  height: 44rpx;
  opacity: 0.6;
}


.intent-item + .intent-item,
.reply-item + .reply-item {
  margin-top: var(--space-16);
}

.composer {
  width: 100%;
  min-height: 132rpx;
  margin-top: var(--space-12);
  padding: var(--space-16);
  border-radius: var(--radius-input);
  background: var(--color-bg-soft);
  border: 2rpx solid var(--color-border-strong);
  color: var(--color-text-primary);
  placeholder-color: var(--color-text-secondary);
}

.composer-actions {
  display: flex;
  align-items: center;
  gap: var(--space-12);
  margin-top: var(--space-16);
}

.composer-clear {
  width: 180rpx;
  flex-shrink: 0;
  border: 2rpx solid var(--color-accent);
  color: var(--color-accent);
  background: transparent;
  border-radius: var(--radius-button);
  font-weight: 500;
}

.send-button {
  flex: 1;
}

.send-button--disabled {
  opacity: 0.45;
}

.finish-button {
  margin-top: var(--space-16);
}

.finish-copy {
  display: block;
  margin: var(--space-12) 0 var(--space-20);
  color: var(--color-text-secondary);
}
