.detail-character-card,
.detail-card {
  padding: var(--space-24);
}

.detail-character-card {
  background: linear-gradient(180deg, #fbf6ef, #f6efe6);
}

.detail-title {
  display: block;
  margin-top: var(--space-12);
  font-size: var(--font-title-xl);
  line-height: 1.2;
}

.detail-copy {
  display: block;
  margin-top: var(--space-12);
  color: var(--color-text-secondary);
}

.detail-meta {
  margin-top: var(--space-12);
}

.detail-tag-row {
  margin-top: var(--space-16);
}

.detail-actions {
  margin-top: var(--space-24);
  display: flex;
  flex-direction: column;
  gap: var(--space-12);
}

.detail-fallback-button {
  margin-top: var(--space-20);
}

.detail-share {
  align-self: center;
}
