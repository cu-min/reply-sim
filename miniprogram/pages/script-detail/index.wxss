/* ── Page ── */
.detail-page {
  min-height: 100vh;
  background: var(--color-bg-page);
  display: flex;
  flex-direction: column;
}

/* ── Custom Nav ── */
.detail-nav {
  background: transparent;
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  z-index: 50;
}

.detail-nav__bar {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 var(--layout-page-padding);
  position: relative;
}

.detail-nav__back {
  position: absolute;
  left: var(--layout-page-padding);
  width: 68rpx;
  height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
}

.detail-nav__back:active {
  opacity: 0.6;
}

.detail-nav__back-arrow {
  font-size: 56rpx;
  color: #fff;
  font-weight: 300;
  line-height: 1;
  margin-top: -4rpx;
}

.detail-nav__title {
  font-size: 34rpx;
  font-weight: 600;
  color: #fff;
  letter-spacing: 2rpx;
}

.detail-nav__placeholder {
  position: absolute;
  right: var(--layout-page-padding);
  width: 68rpx;
}

/* ── Hero ── */
.detail-hero {
  padding-bottom: 48rpx;
  position: relative;
  overflow: hidden;
}

.detail-hero__emoji {
  position: absolute;
  right: 40rpx;
  top: 40rpx;
  font-size: 100rpx;
  opacity: 0.15;
  line-height: 1;
}

.detail-hero__category-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 0 var(--layout-page-padding);
  margin-bottom: 20rpx;
}

.detail-hero__badge {
  padding: 6rpx 20rpx;
  border-radius: 999rpx;
}

.detail-hero__badge-text {
  font-size: 22rpx;
  font-weight: 500;
}

.detail-hero__relation {
  font-size: 24rpx;
}

.detail-hero__name {
  display: block;
  font-size: 64rpx;
  font-weight: 700;
  line-height: 1.2;
  padding: 0 var(--layout-page-padding);
  margin-bottom: 24rpx;
}

.detail-hero__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  padding: 0 var(--layout-page-padding);
  margin-bottom: 24rpx;
}

.detail-hero__tag {
  font-size: 22rpx;
  padding: 6rpx 20rpx;
  border-radius: 999rpx;
  font-weight: 400;
}

.detail-hero__blurb {
  display: block;
  font-size: 26rpx;
  line-height: 1.65;
  padding: 0 var(--layout-page-padding);
}

/* ── Content ── */
.detail-content {
  flex: 1;
  padding: var(--space-24) var(--layout-page-padding) var(--space-16);
}

/* ── Cards ── */
.detail-card {
  background: var(--color-bg-card);
  border-radius: 40rpx;
  padding: 36rpx 32rpx;
  box-shadow: var(--shadow-card);
  margin-bottom: var(--space-16);
}

.detail-card__label {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-muted);
  letter-spacing: 2rpx;
  margin-bottom: 16rpx;
}

.detail-card__body {
  display: block;
  font-size: 28rpx;
  color: var(--color-text-secondary);
  line-height: 1.75;
}

/* ── Opening Bubble ── */
.detail-bubble-row {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
}

.detail-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.detail-avatar__initial {
  font-size: 28rpx;
  color: #fff;
  font-weight: 600;
}

.detail-bubble-col {
  flex: 1;
}

.detail-bubble-meta {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  margin-bottom: 10rpx;
}

.detail-bubble-name {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}

.detail-bubble-time {
  font-size: 22rpx;
  color: var(--color-text-muted);
}

.detail-bubble {
  background: var(--color-bubble-assistant);
  border: 1rpx solid var(--color-bubble-assistant-border);
  border-radius: 4rpx 28rpx 28rpx 28rpx;
  padding: 20rpx 24rpx;
  align-self: flex-start;
  display: inline-flex;
}

.detail-bubble__text {
  font-size: 34rpx;
  font-weight: 500;
  color: var(--color-text-primary);
  line-height: 1.4;
}

/* ── Actions ── */
.detail-actions {
  padding: var(--space-16) var(--layout-page-padding) calc(var(--space-40) + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
  gap: var(--space-12);
}

.detail-start-btn {
  width: 100%;
  min-height: 96rpx;
  border-radius: 24rpx;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 500;
  letter-spacing: 2rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(139, 90, 90, 0.35);
}

.detail-start-btn:active {
  opacity: 0.85;
  transform: scale(0.98);
  transition: all 0.1s ease;
}

.detail-ghost-btn {
  width: 100%;
  min-height: 80rpx;
  border-radius: 20rpx;
  border: 1rpx solid var(--color-accent);
  color: var(--color-accent);
  font-size: 28rpx;
  background: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
}

.detail-share-btn {
  width: 100%;
  min-height: 96rpx;
  border-radius: 24rpx;
  border: 2rpx solid #8B5A5A;
  color: #8B5A5A;
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  background: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.detail-share-icon {
  width: 36rpx;
  height: 36rpx;
}

.detail-share-text {
  font-weight: 600;
}

.detail-share-btn::after {
  border: none;
}

.detail-share-btn:active {
  opacity: 0.7;
  transform: scale(0.98);
  transition: all 0.1s ease;
}

/* ── Hint bar ── */
.hint-bar {
  background: var(--color-bg-muted);
  border-radius: var(--radius-card);
  padding: 24rpx;
  margin-bottom: var(--space-16);
  font-size: var(--font-caption);
  color: var(--color-text-muted);
  line-height: 1.5;
}

/* ── Error state ── */
.detail-page--error .detail-nav .detail-nav__back-arrow {
  color: var(--color-text-primary);
}

.detail-page--error .detail-nav .detail-nav__title {
  color: var(--color-text-primary);
}
