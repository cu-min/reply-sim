.detail-character-card {
  padding: 24rpx;
  background: linear-gradient(180deg, #fbf6ef, #f6efe6);
}

.detail-card {
  padding: 24rpx;
}

.detail-title {
  display: block;
  font-size: 42rpx;
  line-height: 1.3;
}

.detail-opening-bubble {
  margin-top: 18rpx;
  align-self: flex-start;
  padding: 18rpx 22rpx;
  border-radius: var(--radius-bubble);
  background: var(--color-bubble-assistant);
  border: 1rpx solid var(--color-bubble-assistant-border);
}

.detail-opening-text {
  font-size: 34rpx;
  line-height: 1.38;
}

.detail-meta {
  display: block;
  margin-top: 16rpx;
  color: var(--color-text-secondary);
}

.detail-copy {
  display: block;
  margin-top: 14rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
}

.detail-actions {
  margin-top: var(--space-24);
  display: flex;
  flex-direction: column;
  gap: var(--space-12);
}

.detail-fallback-button {
  margin-top: var(--space-20);
}

.detail-share {
  align-self: center;
}
