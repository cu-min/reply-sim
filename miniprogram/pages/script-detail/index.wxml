<view class="page-shell detail-page" wx:if="{{loadState === 'ready' && script}}">
  <view class="surface-card detail-character-card">
    <text class="detail-title serif-title">{{script.title}}</text>
    <view class="detail-opening-bubble">
      <text class="detail-opening-text">{{script.openingLine}}</text>
    </view>
    <text class="meta-line detail-meta">{{script.meta}}</text>
  </view>

  <view class="detail-actions">
    <button class="primary-button" bindtap="handleStartChat">开始这段对话</button>
    <button class="share-btn detail-share" open-type="share" bindtap="handleShareReward">
      <image class="share-icon" src="/assets/icons/share.png" mode="aspectFit" />
      <text>分享给好友</text>
    </button>
  </view>
</view>

<view class="page-shell detail-page" wx:elif="{{loadState === 'error'}}">
  <view class="surface-card detail-card">
    <text class="section-title">暂时打不开这个剧本</text>
    <text class="detail-copy">{{errorMessage}}</text>
    <button class="ghost-button detail-fallback-button" bindtap="handleBackHome">回到首页</button>
  </view>
</view>
