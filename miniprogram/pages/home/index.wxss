.hero-card {
  min-height: 24vh;
  padding: 22rpx 26rpx;
  display: flex;
  align-items: center;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(255, 255, 255, 0.76));
  margin-bottom: 12rpx;
}

.hero-copy-group {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.hero-lead {
  display: block;
  color: var(--color-text-primary);
  font-size: 36rpx;
  line-height: 1.35;
  font-weight: 700;
}

.hero-copy {
  display: block;
  color: var(--color-text-secondary);
  font-size: 26rpx;
  line-height: 1.55;
}

.featured-scroll,
.category-scroll {
  white-space: nowrap;
}

.category-row {
  display: inline-flex;
  flex-wrap: nowrap;
  gap: var(--space-12);
  padding-bottom: 8rpx;
}

.featured-row {
  display: inline-flex;
  gap: var(--space-12);
  padding-bottom: 8rpx;
}

.featured-card {
  width: 560rpx;
  min-height: 286rpx;
  padding: 20rpx 20rpx 18rpx;
  display: inline-flex;
  flex-direction: column;
  justify-content: flex-start;
}

.opening-bubble {
  margin: 0 0 12rpx;
  align-self: flex-start;
  padding: 14rpx 20rpx;
  background: var(--color-bubble-assistant);
  border: 1rpx solid var(--color-bubble-assistant-border);
  border-radius: var(--radius-bubble);
}

.opening-bubble--featured {
  max-width: 100%;
}

.opening-text {
  font-size: 40rpx;
  line-height: 1.24;
}

.featured-copy {
  color: var(--color-text-secondary);
  line-height: 1.55;
}

.card-bottom-row {
  margin-top: auto;
  padding-top: 18rpx;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 18rpx;
}

.card-tags {
  flex: 1;
  min-width: 0;
  font-size: 22rpx;
  line-height: 1.4;
}

.card-unlocked {
  flex-shrink: 0;
  color: var(--color-accent);
  font-size: var(--font-note);
  line-height: 1.3;
  text-align: right;
}

.list-card {
  padding: 20rpx 20rpx 18rpx;
}

.list-card + .list-card {
  margin-top: var(--space-12);
}

.list-card-bubble {
  margin-top: 0;
  padding: 14rpx 20rpx;
  display: inline-flex;
  flex-shrink: 0;
  border-radius: var(--radius-bubble);
  background: var(--color-bubble-assistant);
  border: 1rpx solid var(--color-bubble-assistant-border);
}

.list-card-opening {
  font-size: 30rpx;
  line-height: 1.35;
}

.list-card-meta {
  display: block;
  margin-top: 12rpx;
}

.list-card-copy {
  display: block;
  margin-top: 10rpx;
  color: var(--color-text-secondary);
  line-height: 1.55;
}
