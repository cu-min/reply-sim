/* ── Page ── */
.home-page {
  min-height: 100vh;
  background: var(--color-bg-page);
}

/* ── Custom Nav ── */
.home-nav {
  background: var(--color-bg-page);
  position: sticky;
  top: 0;
  z-index: 50;
  transition: background 0.3s;
}

.home-nav--scrolled {
  background: rgba(245, 240, 232, 0.9);
}

.home-nav__bar {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  padding: 0 var(--layout-page-padding);
}

.home-nav__placeholder {
  width: 68rpx;
}

.home-nav__title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  letter-spacing: 2rpx;
}

.home-nav__right {
  position: absolute;
  right: var(--layout-page-padding);
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.home-nav__dots-btn {
  width: 68rpx;
  height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.home-nav__dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: var(--color-text-muted);
  opacity: 0.6;
}

.home-nav__avatar-btn {
  width: 68rpx;
  height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.home-nav__avatar {
  width: 44rpx;
  height: 44rpx;
  opacity: 0.55;
}

/* ── Content ── */
.home-content {
  padding: var(--space-16) var(--layout-page-padding) calc(var(--space-40) + env(safe-area-inset-bottom));
}

/* ── Section ── */
.home-section {
  margin-bottom: var(--space-24);
}

.home-section--featured {
  margin-left: calc(-1 * var(--layout-page-padding));
  margin-right: calc(-1 * var(--layout-page-padding));
}

.section-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: var(--space-12);
}

.featured-section-head {
  padding-left: var(--layout-page-padding);
  padding-right: var(--layout-page-padding);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.section-note {
  font-size: var(--font-caption);
  color: var(--color-text-muted);
}

/* ── Hero Card ── */
.hero-card {
  background: linear-gradient(135deg, #D4B5A0 0%, #C49A85 50%, #B88A7A 100%);
  border-radius: var(--radius-card);
  padding: 48rpx 44rpx 40rpx;
  position: relative;
  overflow: hidden;
  margin-bottom: var(--space-24);
  box-shadow: 0 12rpx 48rpx rgba(139, 90, 90, 0.2);
}

.hero-quote-deco {
  position: absolute;
  right: -20rpx;
  bottom: -40rpx;
  font-size: 160rpx;
  color: #4A2A1A;
  opacity: 0.1;
  line-height: 1;
}

.hero-eyebrow {
  display: block;
  font-size: 26rpx;
  color: rgba(74, 42, 26, 0.65);
  margin-bottom: 20rpx;
  letter-spacing: 1rpx;
}

.hero-headline {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.5;
  color: #3A1A0A;
  margin-bottom: 24rpx;
}

.hero-desc {
  display: block;
  font-size: 24rpx;
  line-height: 1.7;
  color: rgba(74, 42, 26, 0.6);
}

/* ── Hint bar ── */
.hint-bar {
  background: var(--color-bg-muted);
  border-radius: var(--radius-card);
  padding: 24rpx;
  margin-bottom: var(--space-16);
  font-size: var(--font-caption);
  color: var(--color-text-muted);
  line-height: 1.5;
}

/* ── Featured Scroll ── */
.featured-scroll {
  white-space: nowrap;
}

.featured-row {
  display: inline-flex;
  gap: 24rpx;
  padding: 8rpx var(--layout-page-padding) 16rpx;
}

.featured-card {
  width: 520rpx;
  height: 400rpx;
  border-radius: 40rpx;
  padding: 40rpx 40rpx 32rpx;
  display: inline-flex;
  flex-direction: column;
  justify-content: space-between;
  position: relative;
  overflow: hidden;
  box-shadow: 0 16rpx 56rpx rgba(0, 0, 0, 0.15);
}

.featured-card:active {
  opacity: 0.88;
  transform: scale(0.97);
  transition: all 0.15s ease;
}

.featured-emoji {
  position: absolute;
  right: 32rpx;
  top: 28rpx;
  font-size: 72rpx;
  opacity: 0.2;
  line-height: 1;
}

.featured-top {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  z-index: 1;
}

.featured-cat-label {
  font-size: 22rpx;
  color: rgba(74, 42, 26, 0.5);
  letter-spacing: 1rpx;
}

.featured-scene-desc {
  font-size: 26rpx;
  font-weight: 500;
  line-height: 1.4;
  max-height: 74rpx;
  overflow: hidden;
}

.featured-bubble {
  background: rgba(255, 255, 255, 0.55);
  border-radius: 28rpx 28rpx 28rpx 4rpx;
  padding: 20rpx 28rpx;
  align-self: flex-start;
  z-index: 1;
}

.featured-bubble-text {
  font-size: 34rpx;
  font-weight: 500;
  color: #2C2C2C;
  line-height: 1.3;
}

.featured-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  z-index: 1;
}

.featured-tags-text {
  font-size: 22rpx;
  color: rgba(74, 42, 26, 0.5);
}

.featured-lock-badge {
  font-size: 22rpx;
  color: #8B5A5A;
  background: rgba(255, 255, 255, 0.5);
  padding: 6rpx 20rpx;
  border-radius: 999rpx;
  font-weight: 500;
}

.featured-unlocked-text {
  font-size: 22rpx;
  font-weight: 500;
}

.featured-row-end {
  width: 8rpx;
  flex-shrink: 0;
}

/* ── Category Tabs ── */
.category-tabs-wrap {
  white-space: nowrap;
}

.category-tabs-row {
  display: inline-flex;
  background: var(--color-bg-card);
  border-radius: 999rpx;
  padding: 8rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.cat-tab {
  padding: 14rpx 32rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  color: var(--color-text-muted);
  font-weight: 400;
  white-space: nowrap;
  transition: background 0.2s ease-in-out, color 0.2s ease-in-out;
}

.cat-tab--active {
  background: var(--color-accent);
  color: #ffffff;
  font-weight: 500;
}

.cat-tab:active {
  opacity: 0.7;
}

/* ── List Cards ── */
.list-card {
  display: flex;
  align-items: stretch;
  background: var(--color-bg-card);
  border-radius: 40rpx;
  box-shadow: var(--shadow-card);
  overflow: hidden;
  margin-bottom: var(--space-24);
}

.list-card:active {
  opacity: 0.88;
  transform: scale(0.985);
  transition: all 0.15s ease;
}

.list-card__stripe {
  width: 6rpx;
  flex-shrink: 0;
  margin: 24rpx 0 24rpx 24rpx;
  border-radius: 999rpx;
}

.list-card__body {
  flex: 1;
  padding: 28rpx 32rpx;
}

.list-card__header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.list-card__opening {
  flex: 1;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.4;
  color: var(--color-text-primary);
}

.list-card__badge {
  flex-shrink: 0;
  padding: 6rpx 20rpx;
  border-radius: 999rpx;
}

.list-card__badge-text {
  font-size: 22rpx;
  color: #ffffff;
  font-weight: 500;
  line-height: 1.5;
}

.list-card__blurb {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-muted);
  line-height: 1.6;
  margin-bottom: 16rpx;
  margin-top: 0;
}

.list-card__footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.list-card__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  flex: 1;
  min-width: 0;
}

.list-card__tag {
  font-size: 20rpx;
  color: var(--color-text-muted);
  background: var(--color-bg-page);
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
}

.list-card__lock {
  flex-shrink: 0;
  font-size: 22rpx;
  color: var(--color-accent);
  font-weight: 500;
}

.list-card__unlocked {
  flex-shrink: 0;
  font-size: 22rpx;
  color: var(--color-accent-alt);
  font-weight: 500;
}

/* ── Empty Panel ── */
.empty-panel {
  padding: var(--space-20);
  border-radius: var(--radius-card);
  background: var(--color-bg-muted);
  color: var(--color-text-muted);
  font-size: var(--font-caption);
}
