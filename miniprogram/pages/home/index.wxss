.hero-card {
  padding: var(--space-24);
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(255, 255, 255, 0.74));
}

.hero-copy {
  display: block;
  color: var(--color-text-secondary);
  font-size: var(--font-body);
}

.featured-scroll,
.category-scroll {
  white-space: nowrap;
}

.category-row {
  display: inline-flex;
  flex-wrap: nowrap;
  gap: var(--space-12);
  padding-bottom: 8rpx;
}

.featured-row {
  display: inline-flex;
  gap: var(--space-12);
  padding-bottom: 8rpx;
}

.featured-card {
  width: 560rpx;
  min-height: 360rpx;
  padding: var(--space-20);
  display: inline-flex;
  flex-direction: column;
  justify-content: space-between;
}

.featured-scene {
  font-size: var(--font-caption);
  color: var(--color-text-secondary);
}

.featured-name {
  margin-top: 6rpx;
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

.opening-bubble {
  margin: var(--space-16) 0 var(--space-12);
  align-self: flex-start;
  padding: 20rpx 24rpx;
  background: var(--color-bubble-assistant);
  border: 1rpx solid var(--color-bubble-assistant-border);
  border-radius: var(--radius-bubble);
}

.opening-text {
  font-size: 44rpx;
  line-height: 1.3;
}

.featured-copy {
  margin-top: var(--space-8);
  color: var(--color-text-secondary);
}

.featured-bottom {
  margin-top: var(--space-20);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.featured-badge {
  color: var(--color-accent);
  font-size: var(--font-caption);
}

.featured-dot {
  display: block;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: var(--color-accent);
}

.list-card {
  padding: var(--space-20);
}

.list-card + .list-card {
  margin-top: var(--space-12);
}

.list-card-top,
.list-card-bottom {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--space-12);
}

.list-card-title {
  font-size: 30rpx;
  font-weight: 600;
}

.list-card-tag {
  font-size: var(--font-caption);
  color: #ffffff;
  background: var(--color-accent);
  padding: 6rpx 14rpx;
  border-radius: var(--radius-pill);
}

.list-card-content {
  margin: var(--space-16) 0 var(--space-12);
  display: flex;
  align-items: center;
  gap: var(--space-12);
}

.list-card-bubble {
  padding: 16rpx 20rpx;
  display: inline-flex;
  flex-shrink: 0;
  border-radius: var(--radius-bubble);
  background: var(--color-bubble-assistant);
  border: 1rpx solid var(--color-bubble-assistant-border);
}

.list-card-opening {
  font-size: 30rpx;
}

.list-card-meta {
  flex: 1;
}

.list-card-copy {
  display: block;
  margin-top: var(--space-8);
  color: var(--color-text-secondary);
}

.tag-row {
  display: flex;
  gap: var(--space-8);
  flex-wrap: wrap;
}

.mini-tag {
  padding: 8rpx 16rpx;
  border-radius: var(--radius-pill);
  background: var(--color-bg-soft);
  color: var(--color-text-secondary);
  font-size: var(--font-note);
}

.list-card-unlocked {
  color: var(--color-accent);
  font-size: var(--font-note);
}
