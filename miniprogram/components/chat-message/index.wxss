.emotion-hint {
  text-align: center;
  padding: 12rpx 0 16rpx;
  animation: emotionFade 3s ease-in-out forwards;
}

.emotion-text {
  display: inline-block;
  font-size: 22rpx;
  color: var(--color-accent);
  background: rgba(139, 90, 90, 0.08);
  padding: 6rpx 24rpx;
  border-radius: 999rpx;
  letter-spacing: 0.5rpx;
}

.msg-row {
  display: flex;
  align-items: flex-end;
  gap: 14rpx;
  margin-bottom: 18rpx;
  animation: bubbleFade 0.3s ease-out;
}

.msg-row--user {
  justify-content: flex-end;
}

.msg-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #D4B5A0, #C49A85);
  color: #6B3A2A;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.msg-spacer {
  width: 12rpx;
  flex-shrink: 0;
}

.msg-bubble {
  max-width: 72%;
  padding: 18rpx 22rpx;
  font-size: var(--font-body);
  line-height: 1.65;
  word-break: break-word;
}

.msg-bubble--assistant {
  background: var(--color-bubble-assistant);
  border-radius: 6rpx 28rpx 28rpx 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.msg-bubble--user {
  background: var(--color-bubble-user);
  border-radius: 28rpx 6rpx 28rpx 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(100, 180, 80, 0.2);
}

@keyframes bubbleFade {
  from {
    opacity: 0;
    transform: translateY(10rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes emotionFade {
  0% { opacity: 0; transform: translateY(6rpx); }
  15% { opacity: 1; transform: translateY(0); }
  70% { opacity: 1; }
  100% { opacity: 0.35; }
}
