.reply-card {
  display: flex;
  flex-direction: row;
  align-items: stretch;
  border-radius: var(--radius-card);
  background: #ffffff;
  border: 1rpx solid var(--color-border-soft);
  box-shadow: var(--shadow-card);
  overflow: hidden;
}

.reply-card--active {
  background: var(--color-accent-soft);
  border-color: var(--color-accent);
}

.reply-card-bar {
  width: 8rpx;
  background: var(--color-accent);
  flex-shrink: 0;
  border-radius: 4rpx 0 0 4rpx;
}

.reply-card-body {
  flex: 1;
  padding: var(--space-16);
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.reply-label {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-accent);
  line-height: 1.4;
}

.reply-tone {
  font-size: 24rpx;
  color: var(--color-text-muted);
  line-height: 1.4;
}

.reply-text {
  display: flex;
  align-items: center;
  font-size: 30rpx;
  color: var(--color-text-primary);
  line-height: 1.6;
  margin-top: 10rpx;
}

@keyframes dots {
  0%   { content: ""; }
  33%  { content: "."; }
  66%  { content: ".."; }
  100% { content: "..."; }
}

.loading-dots::after {
  content: "";
  animation: dots 1.2s steps(1, end) infinite;
}

.reply-text--loading text {
  color: var(--color-text-secondary);
}
