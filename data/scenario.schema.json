{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://if-so-reply.local/schema/scenario.schema.json",
  "title": "Scenario",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "category",
    "cover",
    "character",
    "background",
    "scene_prompt",
    "ending_triggers",
    "possible_endings",
    "turns"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "category": {
      "type": "string",
      "minLength": 1
    },
    "cover": {
      "$ref": "#/$defs/cover"
    },
    "character": {
      "$ref": "#/$defs/character"
    },
    "background": {
      "type": "string",
      "minLength": 1
    },
    "scene_prompt": {
      "type": "string",
      "minLength": 1
    },
    "ending_triggers": {
      "$ref": "#/$defs/endingTriggers"
    },
    "possible_endings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/possibleEnding"
      }
    },
    "turns": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/turn"
      }
    }
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "cover": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "opening_message",
        "subtitle",
        "tags"
      ],
      "properties": {
        "opening_message": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "subtitle": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "tags": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        }
      }
    },
    "character": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "gender",
        "age",
        "occupation",
        "relationship",
        "archetype",
        "personality",
        "speaking_style",
        "attitude_to_relationship",
        "initial_mood",
        "initial_favorability",
        "current_attitude"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "gender": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "age": {
          "type": "integer",
          "minimum": 1,
          "maximum": 120
        },
        "occupation": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "relationship": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "archetype": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "personality": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "speaking_style": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "attitude_to_relationship": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "initial_mood": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "initial_favorability": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "current_attitude": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "endingTriggers": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "description",
        "conditions"
      ],
      "properties": {
        "description": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "conditions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        }
      }
    },
    "possibleEnding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "type",
        "label",
        "hint",
        "impact_line",
        "relationship_result",
        "key_behavior_feedback",
        "missed_branch_hint",
        "literary_closing",
        "badge_label"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "type": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "label": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "hint": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "impact_line": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "relationship_result": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "key_behavior_feedback": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "missed_branch_hint": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "literary_closing": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "badge_label": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "reply": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "style_label",
        "style_description",
        "content"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "style_label": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "style_description": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "content": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "strategy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "description",
        "replies"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "label": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "description": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "replies": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/reply"
          }
        }
      }
    },
    "turn": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "assistant_message",
        "emotion_hint",
        "strategies"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "assistant_message": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "emotion_hint": {
          "type": "string"
        },
        "ending_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "ending_prompt": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "strategies": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/strategy"
          }
        }
      },
      "allOf": [
        {
          "if": {
            "required": [
              "ending_prompt"
            ]
          },
          "then": {
            "required": [
              "ending_id"
            ]
          }
        }
      ]
    }
  }
}
